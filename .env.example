# ============================================================
# CupCast SaaS — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://cupcast:password@localhost:5432/cupcast
DB_PASSWORD=changeme

# --- MLflow ---
# Tracking server — used for training runs + registering new models.
# Backend inference does NOT need this (models load directly from GCS).
# Local dev: http://localhost:5000 (docker-compose); Remote: http://<VM_IP>:5000
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts

# --- Model GCS URIs (populated after running ml/register_models.py) ---
# The backend downloads models directly from GCS — no MLflow dependency at
# runtime. Promote a new version = re-register, update these URIs, redeploy.
GCS_MODEL_URI_CLUB=gs://your-bucket/mlflow-artifacts/1/models/m-<id>/artifacts
GCS_MODEL_URI_CLUB_TOP5=gs://your-bucket/mlflow-artifacts/2/models/m-<id>/artifacts
GCS_MODEL_URI_INTL=gs://your-bucket/mlflow-artifacts/3/models/m-<id>/artifacts

# --- GCP (production only) ---
GCP_PROJECT_ID=cupcast-prod
GCP_REGION=us-central1
GCS_BUCKET=cupcast-artifacts

# --- External API Keys ---
# Football-Data.org — free tier; PL, La Liga, Serie A, Bundesliga, Ligue 1, CL, WC
FOOTBALL_DATA_ORG_API_KEY=your_football_data_org_api_key_here
# API-Football (api-sports.io) — UCL, lower leagues, MLS, injuries
API_FOOTBALL_KEYS=your_api_football_key_here
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# --- Scheduler ---
# "true" to enable background score/fixture/prediction refresh jobs.
ENABLE_SCHEDULER=false

# --- Admin API ---
ADMIN_API_KEY=changeme_generate_a_real_secret

# --- Frontend (Vite — prefix with VITE_) ---
VITE_API_URL=http://localhost:8000
