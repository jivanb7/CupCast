# ============================================================
# CupCast SaaS — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://cupcast:password@localhost:5432/cupcast
DB_PASSWORD=changeme

# --- MLflow ---
# Tracking server — used for training runs AND for runtime model loading.
# The backend resolves `models:/<name>@prod` URIs at load time, so Cloud Run
# must reach this endpoint. In prod this is a Caddy-fronted HTTPS URL with
# basic auth; the raw MLflow port stays firewalled to admin IPs.
# Local dev: http://localhost:5000 (docker-compose, no auth)
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts

# --- Registered model names (rarely changes) ---
# Backend loads via models:/<name>@prod. To promote a retrained model:
#   mlflow models set-alias -n <name> -a prod -v <new_version>
# then POST /admin/models/reload to drop the in-memory cache. No redeploy.
MLFLOW_MODEL_CLUB=cupcast-club-model
MLFLOW_MODEL_CLUB_TOP5=cupcast-club-top5-model
MLFLOW_MODEL_INTL=cupcast-international-model

# --- GCP (production only) ---
GCP_PROJECT_ID=cupcast-prod
GCP_REGION=us-central1
GCS_BUCKET=cupcast-artifacts

# --- External API Keys ---
# Football-Data.org — free tier; PL, La Liga, Serie A, Bundesliga, Ligue 1, CL, WC
FOOTBALL_DATA_ORG_API_KEY=your_football_data_org_api_key_here
# API-Football (api-sports.io) — UCL, lower leagues, MLS, injuries
API_FOOTBALL_KEYS=your_api_football_key_here
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# --- Scheduler ---
# "true" to enable background score/fixture/prediction refresh jobs.
ENABLE_SCHEDULER=false

# --- Admin API ---
ADMIN_API_KEY=changeme_generate_a_real_secret

# --- Frontend (Vite — prefix with VITE_) ---
VITE_API_URL=http://localhost:8000
